{
  "name": "hanasand",
  "version": "1.6.6",
  "private": true,
  "scripts": {
    "dev": "PORT=${PORT:-3000} bun --bun next dev --webpack --hostname 0.0.0.0 --port ${PORT:-3000}",
    "build": "bun --bun next build --webpack",
    "start": "PORT=${PORT:-3000} bun --bun next start --hostname 0.0.0.0 --port ${PORT:-3000}",
    "start:docker": "PORT=${PORT:-3001} bun --bun next start --hostname 0.0.0.0 --port ${PORT:-3001}",
    "check:startup": "node scripts/check-ai-hooks.mjs",
    "lint": "bunx eslint .",
    "test:e2e": "bun scripts/run-playwright-status.mjs",
    "test:e2e:auth": "bun scripts/run-playwright-status.mjs tests/auth.spec.ts",
    "test:e2e:mail": "PLAYWRIGHT_STATUS_CHECK_NAME='Playwright mail workspace' bun scripts/run-playwright-status.mjs tests/mail.spec.ts",
    "test:e2e:ai": "PLAYWRIGHT_STATUS_CHECK_NAME='Playwright AI workspace' bun scripts/run-playwright-status.mjs tests/ai-workspace.spec.ts"
  },
  "dependencies": {
    "@tailwindcss/postcss": "^4.2.4",
    "@xterm/addon-fit": "^0.11.0",
    "@xterm/xterm": "^6.0.0",
    "detect-libc": "^2.1.2",
    "dotenv": "^17.4.2",
    "eslint-config-next": "^16.2.4",
    "formik": "^2.4.9",
    "highlight.js": "^11.11.1",
    "lucide-react": "^1.8.0",
    "marked": "^18.0.2",
    "marked-highlight": "^2.2.4",
    "next": "16.2.4",
    "node-cron": "^4.2.1",
    "react": "19.2.5",
    "react-dom": "19.2.5",
    "react-markdown": "^10.1.0",
    "recharts": "^3.8.1",
    "remark-gfm": "^4.0.1",
    "sharp": "^0.34.5",
    "yup": "^1.7.1"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.3.5",
    "@playwright/test": "^1.59.1",
    "@types/node": "^25.6.0",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "eslint": "^10.2.1",
    "postcss": "^8.5.10",
    "tailwindcss": "^4.2.4",
    "typescript": "^6.0.3"
  },
  "overrides": {
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3"
  }
}
