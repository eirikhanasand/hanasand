<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN"
  "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
  <key>Label</key>
  <string>com.hanasand.model</string>

  <key>ProgramArguments</key>
  <array>
    <string>/bin/zsh</string>
    <string>-lc</string>
    <string>cd "$HOME/Library/Application Support/HanasandModel/current" &amp;&amp; exec ./run_model_mac.sh</string>
  </array>

  <key>WorkingDirectory</key>
  <string>/</string>

  <key>EnvironmentVariables</key>
  <dict>
    <key>HANASAND_MODEL_IDLE_MODE</key>
    <string>1</string>
    <key>HANASAND_WEB_SEARCH</key>
    <string>1</string>
    <key>MODEL_PORT</key>
    <string>18081</string>
  </dict>

  <key>RunAtLoad</key>
  <true/>

  <key>KeepAlive</key>
  <dict>
    <key>SuccessfulExit</key>
    <false/>
  </dict>

  <key>ThrottleInterval</key>
  <integer>30</integer>

  <key>StandardOutPath</key>
  <string>__HOME__/Library/Logs/hanasand-model.log</string>

  <key>StandardErrorPath</key>
  <string>__HOME__/Library/Logs/hanasand-model.err.log</string>
</dict>
</plist>
