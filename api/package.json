    "smoke:local": "API_BASE=${API_BASE:-http://127.0.0.1:8080/api} FRONTEND_BASE=${FRONTEND_BASE:-http://127.0.0.1:3000} DB_HOST=${DB_HOST:-127.0.0.1} DB_PORT=${DB_PORT:-8503} bun scripts/smoke-dashboard-runtime.mjs",
    "smoke:docker": "API_BASE=${API_BASE:-http://127.0.0.1:8080/api} FRONTEND_BASE=${FRONTEND_BASE:-http://127.0.0.1:3000} DB_HOST=${DB_HOST:-127.0.0.1} DB_PORT=${DB_PORT:-8503} bun scripts/smoke-dashboard-runtime.mjs"
  },
  "author": "",
  "license": "ISC",
  "description": "",
  "dependencies": {
    "@fastify/cors": "^11.2.0",
    "@fastify/websocket": "^11.2.0",
    "bcrypt": "^6.0.0",
    "dotenv": "^17.4.2",
    "fastify": "^5.8.5",
    "fastify-plugin": "^5.1.0",
    "gray-matter": "^4.0.3",
    "node-cron": "^4.2.1",
    "nodemailer": "^8.0.5",
    "pg": "^8.20.0",
    "ws": "^8.20.0"
  },
  "devDependencies": {
    "@types/bcrypt": "^6.0.0",
    "@types/nodemailer": "^8.0.0",
    "@types/pg": "^8.20.0",
    "@types/ws": "^8.18.1",
    "ts-node": "^10.9.2",
    "typescript": "^6.0.3"
  },
  "imports": {
    "#utils/*": "./src/utils/*",
    "#plugins/*": "./src/plugins/*",
    "#ws": "./src/plugins/ws.ts",
    "#constants": "./src/constants.ts",
    "#components/*": "./src/components/*",
    "#db": "./src/utils/db.ts",
    "#/*": "./src/*"
  }
}
